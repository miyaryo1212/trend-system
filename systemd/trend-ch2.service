[Unit]
Description=Run CH2 Codex/OpenAI trend report
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=miyaryo
WorkingDirectory=/home/miyaryo/project/work/tamago/trend-system
EnvironmentFile=/home/miyaryo/.env.agent
ExecStart=/home/miyaryo/project/work/tamago/trend-system/scripts/run.sh codex-openai
StandardOutput=append:/home/miyaryo/project/work/tamago/trend-system/logs/trend-report.log
StandardError=append:/home/miyaryo/project/work/tamago/trend-system/logs/trend-report.log
TimeoutStartSec=1800
